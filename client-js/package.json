{
  "name": "queen-mq",
  "version": "0.12.2",
  "type": "module",
  "description": "High-performance C++ message queue backed by PostgreSQL",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node test-v2/run.js human"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Smartness",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartpricing/queen"
  },
  "keywords": [
    "message-queue",
    "queue",
    "broker",
    "message-queue-system",
    "fifo"
  ]
}
